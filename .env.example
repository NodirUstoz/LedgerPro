# =============================================================================
# LedgerPro Environment Configuration
# =============================================================================
# Copy this file to .env and update the values for your environment.

# -----------------------------------------------------------------------------
# Django Settings
# -----------------------------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=your-very-long-and-random-secret-key-here
DEBUG=0
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:3000

# -----------------------------------------------------------------------------
# PostgreSQL Database
# -----------------------------------------------------------------------------
POSTGRES_DB=ledgerpro
POSTGRES_USER=ledgerpro
POSTGRES_PASSWORD=your-strong-database-password
POSTGRES_PORT=5432
DATABASE_URL=postgresql://ledgerpro:your-strong-database-password@db:5432/ledgerpro

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PASSWORD=your-strong-redis-password
REDIS_PORT=6379
REDIS_URL=redis://:your-strong-redis-password@redis:6379/0
CELERY_BROKER_URL=redis://:your-strong-redis-password@redis:6379/1

# -----------------------------------------------------------------------------
# Email (SMTP)
# -----------------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-email-app-password
DEFAULT_FROM_EMAIL=noreply@ledgerpro.com

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
REACT_APP_API_URL=http://localhost/api

# -----------------------------------------------------------------------------
# Currency Exchange API (optional)
# -----------------------------------------------------------------------------
EXCHANGE_RATE_API_KEY=your-exchange-rate-api-key
EXCHANGE_RATE_API_URL=https://api.exchangerate-api.com/v4/latest/

# -----------------------------------------------------------------------------
# File Storage (production)
# -----------------------------------------------------------------------------
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_STORAGE_BUCKET_NAME=ledgerpro-media
# AWS_S3_REGION_NAME=us-east-1
